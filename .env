# Server Configuration
PORT=5000
NODE_ENV=development

# Database (Uses local JSON storage if MongoDB is down)
MONGODB_URI=mongodb://localhost:27017/crop_prediction

# JWT Configuration
JWT_SECRET=super_secret_crop_ai_token_key_987654321
JWT_EXPIRE=7d

# Python ML Model & Execution
ML_MODEL_PATH=../ml_models/crop_recommendation_model.pkl
PYTHON_SCRIPT_PATH=./scripts/predict_crop.py
PYTHON_PATH=python

# Cloudinary Configuration (Using local file uploads fallback when empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS Config
FRONTEND_URL=http://localhost:5173
