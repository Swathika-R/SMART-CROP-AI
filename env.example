# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/crop_prediction

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Python ML Model & Execution
ML_MODEL_PATH=./ml_models/crop_recommendation_model.pkl
PYTHON_SCRIPT_PATH=./scripts/predict_crop.py
PYTHON_PATH=python

# Cloudinary Configuration (optional, local disk fallback if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS Config
FRONTEND_URL=http://localhost:5173
